{
  "rules": {
    "tenants": {
      "$tenantId": {
        ".read": "auth != null && root.child('users').child(auth.uid).child('tenantId').val() == $tenantId",
        ".write": "auth != null && root.child('users').child(auth.uid).child('tenantId').val() == $tenantId"
      }
    },
    "users": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "organizations": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "Config": {
      ".read": true,
      ".write": "auth != null"
    }
  }
}
